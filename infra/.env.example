# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme

# ─── Airflow ──────────────────────────────────────────────────────────────────
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=changeme
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme
# UID do seu usuário no host: id -u
AIRFLOW_UID=1000

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme

# ─── ClickHouse ───────────────────────────────────────────────────────────────
CLICKHOUSE_DB=datastack
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=changeme

# ─── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# ─── Superset ─────────────────────────────────────────────────────────────────
# Gerar com: openssl rand -base64 42
SUPERSET_SECRET_KEY=
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=changeme
